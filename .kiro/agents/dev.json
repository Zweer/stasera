{
  "name": "dev",
  "description": "Development agent for Stasera — PWA che consiglia cosa fare il sabato sera a Genova",
  "prompt": "file://../prompts/dev.md",
  "resources": ["file://README.md", "file://.kiro/steering/**/*.md"],
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".kiro/**",
        "app/**",
        "components/**",
        "db/**",
        "lib/**",
        "hooks/**",
        "auth.ts",
        "middleware.ts",
        "next.config.ts",
        "drizzle.config.ts",
        "biome.json",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "postcss.config.mjs",
        ".env.example",
        ".gitignore",
        "public/**",
        "README.md"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        ".*git commit.*",
        ".*git push.*",
        ".*git tag .*",
        ".*npm publish.*"
      ]
    }
  }
}
